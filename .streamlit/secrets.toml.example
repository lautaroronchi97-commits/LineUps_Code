# Plantilla de secrets para Streamlit Community Cloud.
#
# En desarrollo local NO usamos este archivo: leemos de `.env` via python-dotenv.
# Cuando despleguemos la app en share.streamlit.io, copiamos el contenido real
# de aca (con los valores de .env) en la UI de Secrets del dashboard de Streamlit.
#
# NO commitear `secrets.toml` (con valores reales) - ya esta en .gitignore.

SUPABASE_URL = "https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY = "tu_service_role_key_aqui"
