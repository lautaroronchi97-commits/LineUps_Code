# Plantilla de secrets para Streamlit Community Cloud.
#
# En desarrollo local NO usamos este archivo: leemos de `.env` via python-dotenv.
# Cuando despleguemos la app en share.streamlit.io, copiamos el contenido de
# aca (con los valores reales) en la UI de Secrets del dashboard de Streamlit.
#
# SEGURIDAD: usar SUPABASE_ANON_KEY (solo-lectura) para el dashboard publico.
# La clave anon tiene RLS habilitado: nadie puede escribir en la DB aunque la key
# se filtre. La service_role_key queda SOLO en GitHub Actions (cron).
#
# NO commitear `secrets.toml` (con valores reales) - ya esta en .gitignore.

SUPABASE_URL = "https://tu-proyecto.supabase.co"

# Usar anon key aqui (solo-lectura). NO usar service_role en Streamlit Cloud.
SUPABASE_ANON_KEY = "tu_anon_key_aqui"
