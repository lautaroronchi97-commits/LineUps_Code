# Plantilla de credenciales. Copia este archivo a .env y completalo.
#
# .env NO se commitea al repo (esta en .gitignore).
# El archivo .env.example SI va al repo, pero solo con placeholders.

# URL del proyecto Supabase (Settings -> API -> Project URL).
SUPABASE_URL=https://tu-proyecto.supabase.co

# --- Desarrollo local y scripts de cron (backfill, update_today, update_djve) ---
# Service role key (Settings -> API -> service_role).
# Permisos totales sobre la DB (lectura + escritura). No compartir ni commitear.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# --- Dashboard en Streamlit Cloud (opcional pero recomendado) ---
# Anon / publishable key (Settings -> API -> anon / public).
# Solo-lectura: RLS bloquea escrituras aunque la key se filtre.
# Si esta definida, db.py la prioriza sobre SERVICE_ROLE_KEY.
# En local puedes dejarla comentada y usar solo SERVICE_ROLE_KEY.
# SUPABASE_ANON_KEY=tu_anon_key_aqui
